# =============================================================================
# CofradeNet — Variables de entorno globales
# Copia a config/.env y rellena los valores:
#   cp config/.env.example config/.env
#
# URLs públicas (API, CORS) se calculan desde APP_HOST + puertos.
# =============================================================================

APP_HOST=localhost
FRONTEND_PORT=4000
BACKEND_PORT=3000
NODE_ENV=development

# --- Producción (Render, Railway, Fly.io…) ---
# URL pública del frontend (Vite en Cloudflare Pages, etc.) — usada por CORS
# FRONTEND_URL=https://cofradenet.pages.dev
# Varias URLs separadas por coma (preview + producción):
# CORS_ORIGINS=https://cofradenet.pages.dev,http://localhost:5173
# El hosting suele inyectar PORT automáticamente; no hace falta definirlo

# --- Backend: autenticación ---
JWT_SECRET=your_jwt_secret_here

# =============================================================================
# BASE DE DATOS RELACIONAL — Supabase (PostgreSQL)
# Datos de la aplicación: usuarios, hermandades, procesiones, referencias a media…
#
# Desarrollo local con Podman:  npm run db:up  (usa DB_* de abajo)
# Producción / nube con Supabase:
#   1. https://supabase.com → New project
#   2. Settings → Database → Connection string → URI (modo Session o Transaction)
#   3. Pega en DATABASE_URL y comenta DB_*
#   4. SQL Editor → ejecuta config/supabase/init.sql (extensión unaccent)
# =============================================================================

# Si defines DATABASE_URL, ignora DB_HOST/DB_PORT/DB_USERNAME/DB_PASSWORD/DB_NAME
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=cofradenet_db

# =============================================================================
# ALMACENAMIENTO DE MEDIA — Cloudflare R2
# Binarios: imágenes, vídeos, logos…
# PostgreSQL guarda la referencia (tabla archivos); R2 guarda el binario.
#
# Setup R2:
#   1. https://dash.cloudflare.com → R2 → Create bucket
#   2. R2 → Manage R2 API Tokens → Create API token (Object Read & Write)
#   3. Account ID está en la URL del dashboard o en Overview
# =============================================================================

# local = disco en backend/uploads (desarrollo sin nube)
# r2    = Cloudflare R2 (recomendado en producción, 10 GB gratis)
# mongodb = MongoDB Atlas GridFS (legacy, no recomendado)
MEDIA_STORAGE_PROVIDER=local

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=cofradenet-media

# Opcional: URL pública del bucket (custom domain en R2). Si no se define,
# los archivos se sirven vía GET /archivos/:id del backend.
# R2_PUBLIC_URL=https://media.tudominio.com
